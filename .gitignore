# Go community template (https://github.com/github/gitignore/blob/main/community/Golang/Go.gitignore)
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# eBPF artifacts regenerated by `go generate ./...`
trace_*_bpfel.go
trace_*_bpfeb.go
trace_*.o

# Build output
/ebpf-workshop
/trace

# Editor/IDE
# .idea/
# .vscode/
